# Auto Deal Generator - Environment Variables
# Copy this to .env and fill in your API keys

# Fireflies.ai - GraphQL API key
# Get from: https://app.fireflies.ai/integrations/custom/fireflies
FIREFLIES_API_KEY=your_fireflies_api_key_here

# Anthropic Claude API
# Get from: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# HubSpot Private App Token
# Required scopes (confirmed against HubSpot API docs):
#   crm.objects.deals.read
#   crm.objects.deals.write
#   crm.objects.contacts.read
#   crm.objects.contacts.write   (required by v4 association API)
#   crm.objects.companies.read
#   crm.objects.companies.write  (required by v4 association API + company creation)
#   crm.objects.calls.read       (required for HubSpot transcript ingestion)
# Get from: HubSpot Settings > Integrations > Private Apps
HUBSPOT_API_KEY=your_hubspot_pat_here

# Slack Incoming Webhook URL (optional - for notifications)
# Get from: https://api.slack.com/messaging/webhooks
SLACK_WEBHOOK_URL=

# Default scoring framework for automated/batch processing
# Options: custom, bant, spiced, meddic, spin
DEFAULT_FRAMEWORK=custom

# HubSpot Pipeline Configuration
# Find these IDs in HubSpot Settings > Objects > Deals > Pipelines
HUBSPOT_PIPELINE_ID=default
HUBSPOT_STAGE_QUALIFIED=qualifiedtobuy
HUBSPOT_STAGE_REVIEW=appointmentscheduled

# -------------------------------------------------------------------
# Attio CRM (use --crm attio to target Attio instead of HubSpot)
# -------------------------------------------------------------------

# Attio API Token
# Get from: Attio Settings > API > Tokens
# Required scopes: record_permission:read-write, object_configuration:read
ATTIO_API_KEY=your_attio_api_key_here

# Attio Deal Stage Names
# Must match the exact status option names configured in your Attio workspace
ATTIO_DEAL_STAGE_QUALIFIED=Qualified
ATTIO_DEAL_STAGE_REVIEW=Needs Review

# Attio Relationship Attribute Slugs (workspace-specific)
# If deal→company or deal→people associations are failing, check your
# Attio workspace: Settings > Objects > Deals > Attributes
# and update these to match the actual attribute slugs.
ATTIO_DEAL_COMPANY_ATTR=associated_workspace_member
ATTIO_DEAL_PEOPLE_ATTR=associated_people
